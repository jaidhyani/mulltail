#!/usr/bin/env bash
# mulltail — Mullvad-backed Tailscale exit node.
set -euo pipefail

cd "$(dirname "$0")"

bold()  { printf '\033[1m%s\033[0m\n' "$*"; }
dim()   { printf '\033[2m%s\033[0m\n' "$*"; }
green() { printf '\033[32m%s\033[0m\n' "$*"; }
red()   { printf '\033[31m%s\033[0m\n' "$*" >&2; }
warn()  { printf '\033[33m%s\033[0m\n' "$*" >&2; }

ENV_FILE=".env"

require_docker() {
    if ! command -v docker >/dev/null 2>&1; then
        red "docker is not installed or not on PATH."
        red "Install Docker Desktop (mac/win) or docker-ce (linux) and try again."
        exit 1
    fi
    if ! docker compose version >/dev/null 2>&1; then
        red "'docker compose' (v2) is required. Update Docker."
        exit 1
    fi
    if ! docker info >/dev/null 2>&1; then
        red "Cannot talk to the Docker daemon. Is it running?"
        exit 1
    fi
}

prompt() {
    local var="$1" label="$2" default="${3:-}" value=""
    if [ -n "$default" ]; then
        printf '  %s [%s]: ' "$label" "$default" >&2
    else
        printf '  %s: ' "$label" >&2
    fi
    read -r value </dev/tty
    value="${value:-$default}"
    printf -v "$var" '%s' "$value"
}

prompt_secret() {
    local var="$1" label="$2" value=""
    printf '  %s: ' "$label" >&2
    stty -echo </dev/tty
    read -r value </dev/tty
    stty echo </dev/tty
    printf '\n' >&2
    printf -v "$var" '%s' "$value"
}

valid_account() { [[ "$1" =~ ^[0-9]{16}$ ]]; }
valid_authkey() { [[ "$1" =~ ^tskey- ]]; }

setup() {
    bold "mulltail setup"
    dim  "no $ENV_FILE found — let's create one."
    echo
    echo "You'll need:"
    echo "  1. Your Mullvad account number (16 digits) — https://mullvad.net/account"
    echo "  2. A Tailscale auth key — https://login.tailscale.com/admin/settings/keys"
    echo

    local acct authkey hostname location port
    while :; do
        prompt_secret acct "Mullvad account number"
        if valid_account "$acct"; then break; fi
        warn "  → must be exactly 16 digits"
    done
    while :; do
        prompt_secret authkey "Tailscale auth key (tskey-...)"
        if valid_authkey "$authkey"; then break; fi
        warn "  → expected key starting with 'tskey-'"
    done
    prompt hostname "Tailnet hostname for this node" "mulltail"
    prompt location "Default relay region (e.g. us-sea, de-fra)" "us-sea"
    prompt port     "Local port for the UI" "8191"

    umask 077
    cat > "$ENV_FILE" <<EOF
# Generated by 'mulltail up' on $(date -u +%Y-%m-%dT%H:%M:%SZ)
MULLVAD_ACCOUNT_NUMBER=$acct
TS_AUTHKEY=$authkey
TS_HOSTNAME=$hostname
MULLTAIL_LOCATION=$location
MULLTAIL_UI_PORT=$port
MULLTAIL_EXIT_CONTAINER=mulltail-exit
MULLTAIL_UI_CONTAINER=mulltail-ui
EOF
    chmod 600 "$ENV_FILE"
    echo
    green "Wrote $ENV_FILE (chmod 600)."
    dim   "Edit later with: ./mulltail config"
    echo
}

cmd_up() {
    require_docker
    if [ ! -f "$ENV_FILE" ]; then setup; fi
    bold "Bringing up mulltail…"
    docker compose up -d --build
    echo
    green "mulltail is up."
    local port
    port=$(grep -E '^MULLTAIL_UI_PORT=' "$ENV_FILE" | cut -d= -f2)
    port="${port:-8191}"
    cat <<EOF

Next:
  1. Approve the new exit node in your Tailscale admin console:
       https://login.tailscale.com/admin/machines
     Find the host (default: 'mulltail'), enable "Use as exit node".

  2. Publish the relay picker UI on your tailnet (recommended):
       ./mulltail share
     This puts the UI at https://<your-host>.<your-tailnet>.ts.net/ —
     reachable from any signed-in device on your tailnet (laptop, phone,
     tablet). Tailnet-only, HTTPS, no port-forwarding.
     Loopback-only alternative: http://localhost:$port (host only).

  3. On any tailnet device, set this as the exit node:
       tailscale up --exit-node=<hostname>

Logs:     ./mulltail logs
Status:   ./mulltail status
Stop:     ./mulltail down
EOF
}

cmd_down() {
    require_docker
    docker compose down
    green "mulltail stopped. Volumes preserved — './mulltail up' resumes where you left off."
}

cmd_destroy() {
    require_docker
    warn "This will delete the wg config + Tailscale state volumes."
    warn "Your Mullvad device slot and Tailscale node entry will leak — clean those up manually."
    printf "Type 'destroy' to confirm: " >&2
    local ans=""
    read -r ans </dev/tty
    if [ "$ans" != "destroy" ]; then echo "aborted."; exit 1; fi
    docker compose down -v
    green "mulltail volumes deleted."
}

cmd_logs() {
    require_docker
    docker compose logs -f "${@:-}"
}

cmd_status() {
    require_docker
    bold "Containers:"
    docker compose ps
    echo
    bold "Exit IP (via Mullvad):"
    docker compose exec -T exit-node curl -s --max-time 5 https://am.i.mullvad.net/json | python3 -m json.tool 2>/dev/null \
        || warn "  (exit-node not reachable yet)"
    echo
    bold "Tailscale:"
    docker compose exec -T exit-node tailscale status 2>/dev/null || warn "  (tailscale not ready)"
}

cmd_share() {
    require_docker
    bold "Publishing UI on your tailnet via 'tailscale serve'…"
    # The exit-node container is the one on the tailnet; it can reach the ui
    # container by service name on the compose network. After this, the UI
    # is at https://<TS_HOSTNAME>.<your-tailnet>.ts.net/ on any tailnet device.
    if ! docker compose exec -T exit-node tailscale serve --bg --https=443 http://ui:8191 2>&1; then
        red "tailscale serve failed."
        red "Most likely cause: the exit-node hasn't been approved on your tailnet yet."
        red "Approve at https://login.tailscale.com/admin/machines, then re-run."
        exit 1
    fi
    local fqdn
    fqdn=$(docker compose exec -T exit-node tailscale status --self=true --json 2>/dev/null \
        | python3 -c 'import sys,json; print(json.load(sys.stdin)["Self"]["DNSName"].rstrip("."))' 2>/dev/null \
        || true)
    echo
    if [ -n "$fqdn" ]; then
        green "UI is now published on your tailnet:"
        bold  "    https://${fqdn}/"
    else
        green "UI is now published on your tailnet (HTTPS, MagicDNS)."
    fi
    dim   "Reachable from any signed-in tailnet device. Stop with: ./mulltail unshare"
}

cmd_unshare() {
    require_docker
    docker compose exec -T exit-node tailscale serve reset || true
    green "Stopped publishing the UI."
}

cmd_config() {
    if [ ! -f "$ENV_FILE" ]; then
        warn "$ENV_FILE doesn't exist yet — run './mulltail up' first."
        exit 1
    fi
    "${EDITOR:-vi}" "$ENV_FILE"
    echo
    dim "Re-apply changes with: ./mulltail up"
}

cmd_help() {
    cat <<'EOF'
mulltail — Mullvad-backed Tailscale exit node.

Usage:
  ./mulltail up            Build & start (interactive setup if no .env)
  ./mulltail down          Stop containers (state preserved)
  ./mulltail status        Show container + exit IP + tailscale status
  ./mulltail logs [svc]    Tail logs (svc: exit-node | ui)
  ./mulltail share         Publish the UI on your tailnet (tailscale serve)
  ./mulltail unshare       Stop publishing the UI
  ./mulltail config        Edit .env in $EDITOR
  ./mulltail destroy       Stop and delete all state volumes
  ./mulltail help          This message
EOF
}

case "${1:-up}" in
    up)      shift || true; cmd_up "$@" ;;
    down)    shift || true; cmd_down "$@" ;;
    destroy) shift || true; cmd_destroy "$@" ;;
    logs)    shift || true; cmd_logs "$@" ;;
    status)  shift || true; cmd_status "$@" ;;
    share)   shift || true; cmd_share "$@" ;;
    unshare) shift || true; cmd_unshare "$@" ;;
    config)  shift || true; cmd_config "$@" ;;
    help|-h|--help) cmd_help ;;
    *) red "unknown subcommand: $1"; cmd_help; exit 1 ;;
esac
