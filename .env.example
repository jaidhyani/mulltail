# mulltail config — copy to .env and fill in.
# Or run `./mulltail up` and it'll prompt you interactively.

# Your 16-digit Mullvad account number.
# Find it at https://mullvad.net/account
MULLVAD_ACCOUNT_NUMBER=

# A Tailscale auth key. Generate at:
#   https://login.tailscale.com/admin/settings/keys
# Reusable + ephemeral are both fine. Tag with `--advertise-exit-node` ACL
# permissions if your tailnet is locked down.
TS_AUTHKEY=

# Hostname this node will use on your tailnet.
TS_HOSTNAME=mulltail

# Default Mullvad relay region for the first boot. Format: <country>-<city>.
# Examples: us-sea, us-nyc, de-fra, jp-tyo. After first boot you can switch
# any time from the UI.
MULLTAIL_LOCATION=us-sea

# Local port on the host for the relay-picker UI.
MULLTAIL_UI_PORT=8191

# Interface to bind the UI to. Default 127.0.0.1 (loopback only) — the UI
# has the docker socket mounted, which is root-equivalent on the host. To
# reach the UI from elsewhere on your tailnet, prefer `./mulltail share`
# (publishes via Tailscale serve, end-to-end encrypted, tailnet-only)
# rather than binding to 0.0.0.0.
MULLTAIL_UI_BIND=127.0.0.1

# Container names (rarely need changing).
MULLTAIL_EXIT_CONTAINER=mulltail-exit
MULLTAIL_UI_CONTAINER=mulltail-ui
